# 複製這個檔成 .env，填入你的值
# 1) 到 https://aistudio.google.com/apikey 申請免費 Gemini API key
GEMINI_API_KEY=your_free_gemini_api_key_here

# 2) Gemini 模型（免費層建議 gemini-2.5-flash；額度不足可改 gemini-2.0-flash）
GEMINI_MODEL=gemini-2.5-flash

# 3) 你的 Gmail（報告寄給自己）
MY_EMAIL=your_email@gmail.com

# 4) 跟催提醒：我寄出後幾天沒收到回覆就提醒（天）
FOLLOWUP_DAYS=4

# 5) 長信 TL;DR 門檻（字元數，超過就生成摘要）
TLDR_MIN_CHARS=1500

# 6) 是否真的寄出緊急提醒信（true/false；false 時只記錄不寄）
ENABLE_URGENT_ALERT=true
